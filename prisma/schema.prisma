// 1. Configurações do Banco
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. Tabela de Projetos
model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique // URL amigável (ex: /projeto/meu-projeto)
  subtitle    String
  shortDesc   String   // Texto curto para o card na Home
  longDesc    String   // Texto longo para a página do projeto
  coverImage  String   // Imagem principal
  aboutImage  String   // Imagem da seção "About Project"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 3. Tabela de Skills (Arsenal Tecnológico)
model Skill {
  id          String   @id @default(uuid())
  name        String
  description String
  order       Int      @default(0) // Para você poder ordenar quem aparece primeiro
  createdAt   DateTime @default(now())
}

// 4. Tabela de Mensagens (Leads do Formulário)
model Message {
  id          String   @id @default(uuid())
  name        String
  email       String
  company     String
  content     String   // O texto de "Como posso ajudar?"
  isRead      Boolean  @default(false) // Para o admin saber se já leu
  createdAt   DateTime @default(now())
}

// 5. Tabela de Configurações (Perfil e Contatos)
model Setting {
  id           String   @id @default("global") // Só existirá 1 linha dessa tabela
  aboutText    String
  cvUrl        String?
  email        String
  phone        String
  linkedinUrl  String
  instagramUrl String
  updatedAt    DateTime @updatedAt
}